    {
      "cell_type": "code",
      "source": [
        "import statsmodels.api as sm\n",
        "from statsmodels.stats.outliers_influence import OLSInfluence\n",
        "\n",
        "# 1. Fit the standard Ordinary Least Squares (OLS) linear model\n",
        "X = sm.add_constant(df[\"Net_Cl_Change\"])\n",
        "y = df[\"Net_FEV1_Change\"]\n",
        "model = sm.OLS(y, X).fit()\n",
        "\n",
        "# 2. Calculate Cook's Distance for all 50 observations\n",
        "influence = OLSInfluence(model)\n",
        "(cooks_d, p_vals) = influence.cooks_distance\n",
        "\n",
        "# 3. Define the standard statistical threshold: 4 / n\n",
        "threshold = 4 / len(df)\n",
        "\n",
        "# 4. Identify which patients cross the formal leverage threshold\n",
        "df_diagnostics = df.copy()\n",
        "df_diagnostics['Cooks_D'] = cooks_d\n",
        "influential_patients = df_diagnostics[df_diagnostics['Cooks_D'] > threshold]\n",
        "\n",
        "print(f\"=== FORMAL INFLUENCE ANALYSIS (Threshold = {threshold:.3f}) ===\")\n",
        "print(f\"Number of mathematically verified high-leverage observations: {len(influential_patients)}\")\n",
        "print(\"\\nHigh-Leverage Patient Profiles:\")\n",
        "print(influential_patients[[\"Patient_ID\", \"Net_FEV1_Change\", \"Net_Cl_Change\", \"Cooks_D\"]].to_string(index=False))\n"
      ],
