    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "\n",
        "# 1. Set the random seed so your 50 patients stay exactly the same as ours\n",
        "np.random.seed(42)\n",
        "\n",
        "# 2. Put in the real-world registry averages\n",
        "mean_metrics = [13.0, -45.0]  # Average Lung Function change, Average Sweat Chloride drop\n",
        "sd_fev1 = 7.0                 # Standard Deviation for lung function\n",
        "sd_cl = 15.0                  # Standard Deviation for sweat chloride\n",
        "r_population = -0.25          # The weak correlation from the registries\n",
        "\n",
        "# 3. Build the math matrix that links them\n",
        "cov_matrix = [\n",
        "    [sd_fev1**2, r_population * sd_fev1 * sd_cl],\n",
        "    [r_population * sd_fev1 * sd_cl, sd_cl**2]\n",
        "]\n",
        "\n",
        "# 4. Generate our 50 true-to-life patients\n",
        "raw_data = np.random.multivariate_normal(mean_metrics, cov_matrix, 50)\n",
        "df = pd.DataFrame(raw_data, columns=[\"Net_FEV1_Change\", \"Net_Cl_Change\"])\n",
        "df.insert(0, \"Patient_ID\", [f\"CF-{i+300}\" for i in range(50)])\n",
        "df = df.round(1)\n",
        "\n",
        "# 5. Look at the first 5 patients to make sure it worked\n",
        "print(df.head())"
      ],
